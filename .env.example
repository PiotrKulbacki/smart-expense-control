# =============================================================================
# Smart Expense Control — Environment Variables
# =============================================================================
# Skopiuj ten plik jako .env w katalogu głównym i uzupełnij wartości.
# Zmienne publiczne (NEXT_PUBLIC_*, EXPO_PUBLIC_*) trafiają do bundle klienta.
# Zmienne bez prefiksu są TAJNE — tylko backend / serwer.
# =============================================================================

# --- Baza danych (TAJNE — tylko backend) ---
DATABASE_URL=postgresql://user:password@localhost:5432/smart_expense_control

# --- Auth / OAuth (TAJNE) ---
# AUTH_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- AI — skaner paragonów & czat asystenta (TAJNE) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Stripe — subskrypcje (TAJNE) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Stripe (PUBLICZNE — web) ---
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Kursy walut PLN/EUR/GBP (TAJNE) ---
# CURRENCY_API_KEY=

# --- PostHog — analityka & feature flags (PUBLICZNE) ---
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# EXPO_PUBLIC_POSTHOG_KEY=
# EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Sentry — monitoring błędów (PUBLICZNE) ---
# NEXT_PUBLIC_SENTRY_DSN=
# EXPO_PUBLIC_SENTRY_DSN=

# --- Aplikacja web (PUBLICZNE) ---
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Aplikacja mobile (PUBLICZNE) ---
# EXPO_PUBLIC_API_URL=http://localhost:3000
