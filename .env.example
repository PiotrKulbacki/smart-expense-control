# =============================================================================
# Smart Expense Control — Environment Variables
# =============================================================================
# Skopiuj ten plik jako .env w katalogu głównym i uzupełnij wartości.
# Zmienne publiczne (NEXT_PUBLIC_*, EXPO_PUBLIC_*) trafiają do bundle klienta.
# Zmienne bez prefiksu są TAJNE — tylko backend / serwer.
# =============================================================================

# --- Baza danych Supabase (TAJNE — tylko backend) ---
# UWAGA: Hasło wklej BEZ nawiasów kwadratowych! Znaki specjalne muszą być URL-encoded.
# Runtime aplikacji (Vercel / Next.js API): Transaction Pooler, port 6543
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Migracje Prisma (db:migrate:deploy):
# - Lokalnie: direct connection — host db.*.supabase.co, user: postgres, port 5432
# - Vercel/CI: Session pooler (NIE db.*.supabase.co — P1001 przez IPv6)! Port 5432 na pooler:
DIRECT_DATABASE_URL=postgresql://postgres.[PROJECT_REF]:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
# Przykład direct (tylko lokalnie): postgresql://postgres:PASSWORD@db.[PROJECT_REF].supabase.co:5432/postgres

# --- Auth / OAuth (TAJNE) ---
# Wygeneruj: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-random-string-at-least-32-characters-long
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI — skaner paragonów & czat asystenta (TAJNE) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# ENABLE_AI=true
# NEXT_PUBLIC_ENABLE_AI=true

# --- Stripe — subskrypcje (TAJNE) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
    "# STRIPE_PRO_PRICE_PLN=
# STRIPE_PRO_PRICE_EUR=
# STRIPE_PRO_PRICE_GBP=

# --- Stripe (PUBLICZNE — web) ---
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Upstash Redis — rate limiting (TAJNE) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Vercel Cron — reset limitów AI (TAJNE) ---
# CRON_SECRET=

# --- Kursy walut PLN/EUR/GBP (TAJNE) ---
# CURRENCY_API_KEY=

# --- PostHog — analityka & feature flags ---
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# POSTHOG_API_KEY=  # serwer (opcjonalnie; fallback: NEXT_PUBLIC_POSTHOG_KEY)
# EXPO_PUBLIC_POSTHOG_KEY=
# EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Sentry — monitoring błędów (PUBLICZNE) ---
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=  # opcjonalnie — upload source maps w CI
# EXPO_PUBLIC_SENTRY_DSN=

# --- Aplikacja web (PUBLICZNE) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Aplikacja mobile (PUBLICZNE) ---
EXPO_PUBLIC_API_URL=http://localhost:3000

# --- CI / lokalny dev bez pełnej konfiguracji ---
# SKIP_ENV_VALIDATION=true
