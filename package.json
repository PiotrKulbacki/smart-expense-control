{
  "name": "smart-expense-control",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.9.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:generate": "npm run generate -w @smart-expense-control/database",
    "db:migrate": "npm run migrate:dev -w @smart-expense-control/database",
    "db:migrate:deploy": "dotenv -e .env -- npm run migrate:deploy -w @smart-expense-control/database",
    "db:status": "npm run migrate:status -w @smart-expense-control/database",
    "db:seed": "npm run db:seed -w @smart-expense-control/database"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
