generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Plan {
  FREE
  PRO
}

enum Currency {
  PLN
  EUR
  GBP
}

enum Frequency {
  MONTHLY
  YEARLY
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  name                   String?
  passwordHash           String?
  avatarUrl              String?
  createdAt              DateTime  @default(now())
  stripeCustomerId       String?   @unique
  currentPlan            Plan      @default(FREE)
  monthlyAiScansCount    Int       @default(0)
  monthlyAiChatCount     Int       @default(0)
  primaryCurrency        Currency  @default(PLN)
  financialMonthStartDay Int       @default(1)
  defaultMonthlyBudget   Float?
  currentMonthBudget     Float?
  lastQuotaResetAt       DateTime?
  pastDueSince           DateTime?

  accounts          Account[]
  sessions          Session[]
  refreshTokens     RefreshToken[]
  transactions      Transaction[]
  recurringExpenses RecurringExpense[]
  chatMessages      ChatMessage[]

  @@map("users")
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("chat_messages")
}

model Account {
  id                String @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Decimal  @db.Decimal(12, 2)
  currency    Currency
  category    String
  description String?
  date        DateTime
  isAiScanned Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("transactions")
}

model RecurringExpense {
  id          String    @id @default(cuid())
  userId      String
  amount      Decimal   @db.Decimal(12, 2)
  currency    Currency
  category    String
  frequency   Frequency
  nextDueDate DateTime
  isActive    Boolean   @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, nextDueDate])
  @@map("recurring_expenses")
}

model ProcessedStripeEvent {
  eventId     String    @id
  type        String
  status      String
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@map("processed_stripe_events")
}

model ExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency Currency
  toCurrency   Currency
  rate         Decimal  @db.Decimal(18, 8)
  fetchedAt    DateTime @default(now())

  @@index([fromCurrency, toCurrency, fetchedAt])
  @@map("exchange_rates")
}
