{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@shared/*": ["./packages/shared/src/*"],
      "@web/*": ["./apps/web/src/*"],
      "@mobile/*": ["./apps/mobile/src/*"]
    }
  }
}
